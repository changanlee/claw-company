{
  // ============================================
  // OpenClaw One-Person Company — Multi-Agent Architecture Config
  // Version: v0.1 Skeleton Phase
  // Date: 2026-03-06
  // ============================================

  // ============================================
  // Model Allowlist — define once, reference by alias
  // To swap models, only change this section
  // ============================================
  "models": {
    "allowlist": [
      { "id": "{{MODEL_PRIMARY}}", "alias": "smart" },
      { "id": "{{MODEL_LIGHT}}", "alias": "fast" }
    ]
  },

  "agents": {
    "defaults": {
      "subagents": {
        "maxSpawnDepth": 2,
        "maxChildrenPerAgent": 5,
        "maxConcurrent": 8,
        "runTimeoutSeconds": 900
      },
      "heartbeat": {
        "every": "30m",
        "activeHours": { "start": "06:00", "end": "23:00" }
      },
      "model": {
        "primary": "smart",
        "fallbacks": ["fast"]
      }
    },
    "list": [
      // ---- Layer 1: CEO ----
      {
        "id": "ceo",
        "default": true,
        "workspace": "~/.openclaw/claw-company/workspace-ceo",
        "agentDir": "~/.openclaw/claw-company/agents/ceo/agent",
        "model": "{{TIER_CEO}}",
        "identity": {
          "name": "CEO",
          "emoji": "👔"
        },
        "subagents": {
          "allowAgents": ["cfo", "cio", "coo", "cto", "chro"]
        }
      },

      // ---- Layer 2: C-Suite Executives ----
      {
        "id": "cfo",
        "workspace": "~/.openclaw/claw-company/workspace-cfo",
        "agentDir": "~/.openclaw/claw-company/agents/cfo/agent",
        "model": "{{TIER_CFO}}",
        "identity": {
          "name": "CFO",
          "emoji": "💰"
        }
      },
      {
        "id": "cio",
        "workspace": "~/.openclaw/claw-company/workspace-cio",
        "agentDir": "~/.openclaw/claw-company/agents/cio/agent",
        "model": "{{TIER_CIO}}",
        "identity": {
          "name": "CIO",
          "emoji": "📈"
        }
      },
      {
        "id": "coo",
        "workspace": "~/.openclaw/claw-company/workspace-coo",
        "agentDir": "~/.openclaw/claw-company/agents/coo/agent",
        "model": "{{TIER_COO}}",
        "identity": {
          "name": "COO",
          "emoji": "🏠"
        }
      },
      {
        "id": "cto",
        "workspace": "~/.openclaw/claw-company/workspace-cto",
        "agentDir": "~/.openclaw/claw-company/agents/cto/agent",
        "model": "{{TIER_CTO}}",
        "identity": {
          "name": "CTO",
          "emoji": "⚙️"
        },
        "subagents": {
          "allowAgents": ["*"],
          "model": "{{TIER_CTO_SUB}}"
        }
      },
      {
        "id": "chro",
        "workspace": "~/.openclaw/claw-company/workspace-chro",
        "agentDir": "~/.openclaw/claw-company/agents/chro/agent",
        "model": "{{TIER_CHRO}}",
        "identity": {
          "name": "CHRO",
          "emoji": "🧬"
        }
      },

      // ---- Independent Oversight: CAO (Chief Audit Officer) ----
      {
        "id": "cao",
        "workspace": "~/.openclaw/claw-company/workspace-cao",
        "agentDir": "~/.openclaw/claw-company/agents/cao/agent",
        "model": "{{TIER_CAO}}",
        "identity": {
          "name": "CAO",
          "emoji": "🛡️"
        }
      }
    ]
  },

  // ============================================
  // Inter-Agent Communication
  // ============================================
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["ceo", "cfo", "cio", "coo", "cto", "chro", "cao"]
    },
    "loopDetection": {
      "enabled": true,
      "historySize": 30,
      "warningThreshold": 10,
      "criticalThreshold": 20
    }
  },

  // ============================================
  // Channel Bindings
  // ============================================
  "channels": {
    "telegram": {
      "accounts": {
        "default": {
          "botToken": "YOUR_CEO_BOT_TOKEN",
          "dmPolicy": "pairing"
        },
        "audit": {
          "botToken": "YOUR_CAO_BOT_TOKEN",
          "dmPolicy": "allowlist",
          "allowFrom": ["YOUR_TELEGRAM_ID"]
        }
      }
    },
    "whatsapp": {
      "dmPolicy": "pairing",
      "textChunkLimit": 4000,
      "sendReadReceipts": true,
      "groups": { "*": { "requireMention": true } }
    },
    "discord": {
      "enabled": true,
      "token": "YOUR_DISCORD_BOT_TOKEN",
      "dmPolicy": "pairing"
    }
  },

  // ============================================
  // Channel-to-Agent Route Bindings
  // ============================================
  "bindings": [
    // All channels default to CEO
    { "agentId": "ceo", "match": { "channel": "telegram", "accountId": "default" } },
    { "agentId": "ceo", "match": { "channel": "whatsapp" } },
    { "agentId": "ceo", "match": { "channel": "discord" } },
    // CAO has independent Telegram bot
    { "agentId": "cao", "match": { "channel": "telegram", "accountId": "audit" } }
  ],

  // ============================================
  // Session Management
  // ============================================
  "session": {
    "scope": "per-sender",
    "reset": {
      "mode": "daily",
      "atHour": 4,
      "idleMinutes": 60
    },
    "maintenance": {
      "mode": "warn",
      "pruneAfter": "30d",
      "maxEntries": 500
    }
  },

  // ============================================
  // Cron Scheduling
  // ============================================
  "cron": {
    "enabled": true,
    "maxConcurrentRuns": 2,
    "sessionRetention": "24h"
  },

  // ============================================
  // Gateway Settings
  // ============================================
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": {
      "mode": "token",
      "token": "YOUR_GATEWAY_TOKEN"
    }
  }
}